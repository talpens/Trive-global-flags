rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string
    //   - email: string (required)
    //   - photoURL: string
    //   - highScore: number
    //   - totalScore: number
    //   - mistakes: map (questionId -> count)
    //   - completedStages: list
    //
    // Collection: leaderboard
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required)
    //   - displayName: string
    //   - score: number (required)
    //   - stage: number
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.uid is string && 
             data.email is string && 
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('highScore' in data) || data.highScore is number) &&
             (!('totalScore' in data) || data.totalScore is number);
    }

    function isValidScore(data) {
      return data.uid == request.auth.uid &&
             data.score is number &&
             data.timestamp is timestamp &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can only read their own private data
      allow read: if isOwner(userId);
      
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                    request.resource.data.uid == resource.data.uid &&
                    request.resource.data.email == resource.data.email;
    }

    match /leaderboard/{scoreId} {
      // Leaderboard is public for authenticated users
      allow read: if isAuthenticated();
      
      // Users can only create their own scores
      allow create: if isAuthenticated() && isValidScore(request.resource.data);
      
      // Scores are immutable once posted
      allow update, delete: if false;
    }
  }
}
